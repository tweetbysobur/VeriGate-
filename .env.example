# VeriGate — Cleanverse backend configuration
# Copy to .env.local and fill in to go live. Defaults to mock mode if unset.

# Public site URL — used for canonical links and social-share (OG) metadata.
# Set to your live domain once registered.
NEXT_PUBLIC_SITE_URL=https://paywithverigate.com

# Optional durable storage for invoices + payment ledger. Add a KV store in
# Vercel (or Upstash) and it injects these — the app uses it automatically.
# Without them, storage falls back to in-process memory (fine for a demo).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- On-chain settlement (Monad) ---
# Wallet settlement target network: "testnet" (default) or "mainnet".
NEXT_PUBLIC_MONAD_NETWORK=testnet
# The aUSDC A-Token customers settle with on Monad (Cleanverse).
NEXT_PUBLIC_MONAD_ATOKEN=0xaC0893567D43C3E7e6e35a72803df05416C1f20D
NEXT_PUBLIC_MONAD_ATOKEN_DECIMALS=6


# "mock" (default, no credentials) or "live"
CLEANVERSE_MODE=mock

# "sandbox" (uatapi.cleanverse.com) or "production" (api.cleanverse.com)
CLEANVERSE_ENV=sandbox

# Optional: override the cooperate API base URL entirely. Set this once
# Cleanverse confirms the real production URL (the documented api.cleanverse.com
# currently does not serve the cooperate endpoints).
# e.g. CLEANVERSE_BASE_URL=https://<prod-host>/api/cooperate
CLEANVERSE_BASE_URL=

# Issued by Cleanverse. Sent as the `api-id` request header.
# Required for live mode. The read-only checkout pipeline needs ONLY this.
CLEANVERSE_API_ID=

# Issued by Cleanverse. Base64. Used LOCALLY to AES-encrypt write-endpoint
# bodies — never sent over the wire, never exposed to the browser.
# Only needed when calling encrypted (write) endpoints, e.g. issuing A-Tokens.
CLEANVERSE_API_KEY=

# Optional: a registered validator compliance pool address. If set, the
# checkout's compliance step screens the wallet against this pool. If unset,
# that step is skipped (the A-Token's own rule is already enforced at identity).
CLEANVERSE_VALIDATOR_POOL=
