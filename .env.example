# VeriGate — Cleanverse backend configuration
# Copy to .env.local and fill in to go live. Defaults to mock mode if unset.

# Public site URL — used for canonical links and social-share (OG) metadata.
# Set to your live domain once registered.
NEXT_PUBLIC_SITE_URL=https://paywithverigate.com


# "mock" (default, no credentials) or "live"
CLEANVERSE_MODE=mock

# "sandbox" (uatapi.cleanverse.com) or "production" (api.cleanverse.com)
CLEANVERSE_ENV=sandbox

# Issued by Cleanverse. Sent as the `api-id` request header.
# Required for live mode. The read-only checkout pipeline needs ONLY this.
CLEANVERSE_API_ID=

# Issued by Cleanverse. Base64. Used LOCALLY to AES-encrypt write-endpoint
# bodies — never sent over the wire, never exposed to the browser.
# Only needed when calling encrypted (write) endpoints, e.g. issuing A-Tokens.
CLEANVERSE_API_KEY=
